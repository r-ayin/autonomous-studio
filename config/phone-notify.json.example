{
  "_说明": "Claude Code → 手机系统通知配置",
  "_优先级分层": "confirm=high+震动 | stop=high+震动 — 只要 Claude 等你，都强提醒",
  "enabled": true,
  "tunnel": {
    "_note": "Termux TCP 隧道（首选方案，零第三方依赖）",
    "host": "127.0.0.1",
    "port": 9999,
    "timeout": 3
  },
  "ntfy": {
    "_note": "ntfy.sh 备选方案（需安装 ntfy app）",
    "server": "https://ntfy.sh",
    "topic": "your-topic-name-change-me"
  },
  "preferences": {
    "stop_priority": "high",
    "_stop_priority_note": "Stop = Claude 等你回复，也是强提醒。high(震动) / default / low(无震动) / min(静默)",
    "stop_debounce_seconds": 0,
    "_stop_debounce_note": "Stop 去抖秒数。0=不去抖。觉得太频繁就设 30-60"
  }
}