{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Redis Writer Schema",
  "description": "Redis writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "redis",
      "description": "Redis writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "expireTime": {
          "type": "object",
          "properties": {
            "seconds": {
              "type": "string"
            },
            "unixtime": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "keyFieldDelimiter": {
          "type": "string"
        },
        "dateFormat": {
          "type": "string"
        },
        "datasource": {
          "type": "string"
        },
        "selectDatabase": {
          "type": "string"
        },
        "writeMode": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            },
            "valueFieldDelimiter": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "keyIndexes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer"
          }
        },
        "batchSize": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "timeout": {
          "type": "integer"
        },
        "redisMode": {
          "type": "string"
        },
        "column": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "index": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "index"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "datasource",
        "keyIndexes"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
