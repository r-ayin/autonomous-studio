{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OTS Reader Schema",
  "description": "OTS (Table Store) reader configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIReaderBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "ots",
      "description": "OTS reader type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "datasource": {
          "type": "string",
          "description": "Datasource name in DataWorks"
        },
        "table": {
          "type": "string",
          "description": "OTS table name"
        },
        "newVersion": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ],
          "description": "Whether to use the new OTS reader"
        },
        "mode": {
          "type": "string",
          "description": "OTS read mode"
        },
        "isTimeseriesTable": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ],
          "description": "Whether the source table is a timeseries table"
        },
        "measurementName": {
          "type": "string",
          "description": "Measurement name used for timeseries reads"
        },
        "column": {
          "type": "array",
          "description": "OTS column definitions",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Column name"
              },
              "type": {
                "type": "string",
                "description": "Column type"
              },
              "value": {
                "type": "string",
                "description": "Constant column value"
              },
              "is_timeseries_tag": {
                "type": "string",
                "enum": [
                  "true",
                  "false"
                ],
                "description": "Whether the column is a timeseries tag"
              }
            },
            "additionalProperties": true
          }
        },
        "range": {
          "type": "object",
          "description": "Range configuration for OTS reads",
          "properties": {
            "begin": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": true
              }
            },
            "end": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": true
              }
            },
            "split": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "required": [
        "datasource",
        "table",
        "column"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
