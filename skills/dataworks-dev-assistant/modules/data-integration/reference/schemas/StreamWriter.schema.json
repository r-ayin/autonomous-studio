{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stream Writer Schema",
  "description": "Stream writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "stream",
      "description": "Stream writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "print": {
          "type": "boolean",
          "description": "Whether to print output to stdout"
        },
        "fieldDelimiter": {
          "type": "string",
          "description": "Field delimiter used when printing records"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
