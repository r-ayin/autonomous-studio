{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Oracle Writer Schema",
  "description": "Oracle writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "oracle",
      "description": "Oracle writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "column": {
          "type": "array",
          "description": "Column names to write to the table",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "datasource": {
          "type": "string",
          "description": "Datasource name in DataWorks"
        },
        "table": {
          "type": "string",
          "description": "Table name to write to"
        },
        "preSql": {
          "type": "array",
          "description": "SQL statements to execute before writing data",
          "items": {
            "type": "string"
          }
        },
        "postSql": {
          "type": "array",
          "description": "SQL statements to execute after writing data",
          "items": {
            "type": "string"
          }
        },
        "writeMode": {
          "type": "string",
          "description": "Write mode: insert",
          "enum": [
            "insert"
          ]
        },
        "batchSize": {
          "type": "integer",
          "description": "Batch size for insert operations"
        },
        "username": {
          "type": "string",
          "description": "Database username"
        },
        "password": {
          "type": "string",
          "description": "Database password"
        },
        "jdbcUrl": {
          "type": "string",
          "description": "JDBC connection URL"
        },
        "session": {
          "type": "array",
          "description": "Session parameters",
          "items": {
            "type": "string"
          }
        },
        "ignoreDuplicate": {
          "type": "boolean",
          "description": "Whether to ignore duplicate key errors"
        },
        "trimString": {
          "type": "boolean",
          "description": "Whether to trim string values"
        },
        "oracleSid": {
          "type": "string",
          "description": "Oracle SID"
        },
        "serviceName": {
          "type": "string",
          "description": "Oracle service name"
        }
      },
      "required": [
        "column",
        "datasource",
        "table"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
