{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DI Job Schema",
  "description": "Complete DataWorks Data Integration job configuration with readers, writers, and settings",
  "type": "object",
  "properties": {
    "type": {
      "const": "job",
      "description": "DI job type"
    },
    "version": {
      "const": "2.0",
      "description": "DI job version"
    },
    "steps": {
      "type": "array",
      "description": "Array of reader and writer steps",
      "minItems": 2,
      "items": {
        "oneOf": [
          {
            "$ref": "ADSWriter.schema.json"
          },
          {
            "$ref": "ClickHouseReader.schema.json"
          },
          {
            "$ref": "ClickHouseWriter.schema.json"
          },
          {
            "$ref": "DatahubReader.schema.json"
          },
          {
            "$ref": "DatahubWriter.schema.json"
          },
          {
            "$ref": "DorisWriter.schema.json"
          },
          {
            "$ref": "DRDSReader.schema.json"
          },
          {
            "$ref": "DRDSWriter.schema.json"
          },
          {
            "$ref": "ElasticsearchReader.schema.json"
          },
          {
            "$ref": "ElasticsearchWriter.schema.json"
          },
          {
            "$ref": "FTPReader.schema.json"
          },
          {
            "$ref": "FTPWriter.schema.json"
          },
          {
            "$ref": "HiveReader.schema.json"
          },
          {
            "$ref": "HiveWriter.schema.json"
          },
          {
            "$ref": "HoloReader.schema.json"
          },
          {
            "$ref": "HoloWriter.schema.json"
          },
          {
            "$ref": "KafkaReader.schema.json"
          },
          {
            "$ref": "LindormReader.schema.json"
          },
          {
            "$ref": "LindormWriter.schema.json"
          },
          {
            "$ref": "LoghubReader.schema.json"
          },
          {
            "$ref": "LoghubWriter.schema.json"
          },
          {
            "$ref": "MetaQWriter.schema.json"
          },
          {
            "$ref": "MongoDBReader.schema.json"
          },
          {
            "$ref": "MongoDBWriter.schema.json"
          },
          {
            "$ref": "MySQLReader.schema.json"
          },
          {
            "$ref": "MySQLWriter.schema.json"
          },
          {
            "$ref": "OceanBaseV10Reader.schema.json"
          },
          {
            "$ref": "OceanBaseV10Writer.schema.json"
          },
          {
            "$ref": "ODPSReader.schema.json"
          },
          {
            "$ref": "ODPSWriter.schema.json"
          },
          {
            "$ref": "OracleReader.schema.json"
          },
          {
            "$ref": "OracleWriter.schema.json"
          },
          {
            "$ref": "OSSReader.schema.json"
          },
          {
            "$ref": "OSSWriter.schema.json"
          },
          {
            "$ref": "OTSReader.schema.json"
          },
          {
            "$ref": "OTSWriter.schema.json"
          },
          {
            "$ref": "PaimonWriter.schema.json"
          },
          {
            "$ref": "PostgreSQLReader.schema.json"
          },
          {
            "$ref": "PostgreSQLWriter.schema.json"
          },
          {
            "$ref": "RDBMSWriter.schema.json"
          },
          {
            "$ref": "RedisWriter.schema.json"
          },
          {
            "$ref": "SAPHANAReader.schema.json"
          },
          {
            "$ref": "SelectDBWriter.schema.json"
          },
          {
            "$ref": "SQLServerReader.schema.json"
          },
          {
            "$ref": "SQLServerWriter.schema.json"
          },
          {
            "$ref": "StarRocksReader.schema.json"
          },
          {
            "$ref": "StarRocksWriter.schema.json"
          },
          {
            "$ref": "StreamReader.schema.json"
          },
          {
            "$ref": "StreamWriter.schema.json"
          },
          {
            "$ref": "TDDLReader.schema.json"
          },
          {
            "$ref": "TairWriter.schema.json"
          }
        ]
      }
    },
    "order": {
      "type": "object",
      "description": "Execution order and dependencies between steps",
      "properties": {
        "hops": {
          "type": "array",
          "description": "Hops defining the flow from reader to writer",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string",
                "description": "Source step name"
              },
              "to": {
                "type": "string",
                "description": "Destination step name"
              }
            },
            "required": [
              "from",
              "to"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "hops"
      ],
      "additionalProperties": true
    },
    "setting": {
      "type": "object",
      "description": "Job-level settings for performance and error handling",
      "properties": {
        "errorLimit": {
          "type": "object",
          "description": "Error handling settings",
          "properties": {
            "record": {
              "type": "string",
              "description": "Maximum number of error records allowed"
            }
          },
          "required": [
            "record"
          ],
          "additionalProperties": true
        },
        "speed": {
          "type": "object",
          "description": "Transfer speed settings",
          "properties": {
            "throttle": {
              "type": "boolean",
              "description": "Whether to enable throttling"
            },
            "concurrent": {
              "type": "integer",
              "description": "Number of concurrent channels"
            },
            "mbps": {
              "type": "integer",
              "description": "Throughput limit in Mbps when throttling is enabled"
            }
          },
          "required": [
            "throttle",
            "concurrent"
          ],
          "additionalProperties": true
        }
      },
      "required": [
        "errorLimit",
        "speed"
      ],
      "additionalProperties": true
    },
    "extend": {
      "type": "object",
      "description": "Additional runtime metadata",
      "properties": {
        "resourceGroup": {
          "type": "string",
          "description": "Runtime resource group identifier",
          "minLength": 1
        },
        "cu": {
          "type": "string",
          "description": "CU size for the job"
        },
        "mode": {
          "type": "string",
          "description": "Job mode",
          "enum": [
            "wizard",
            "code"
          ]
        },
        "__new__": {
          "const": "true",
          "description": "Marks a newly created job"
        }
      },
      "required": [
        "resourceGroup",
        "cu",
        "mode",
        "__new__"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "version",
    "steps",
    "order",
    "setting",
    "extend"
  ],
  "allOf": [
    {
      "properties": {
        "steps": {
          "contains": {
            "type": "object",
            "properties": {
              "category": {
                "const": "reader"
              }
            },
            "required": [
              "category"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "steps": {
          "contains": {
            "type": "object",
            "properties": {
              "category": {
                "const": "writer"
              }
            },
            "required": [
              "category"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
