{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loghub Writer Schema",
  "description": "Loghub writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "enum": [
        "loghub",
        "LogHub"
      ],
      "description": "Loghub writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "datasource": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "accessKeyId": {
          "type": "string"
        },
        "accessKeySecret": {
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "logstore": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "batchSize": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "column": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "time": {
          "type": "string"
        },
        "timeformat": {
          "type": "string"
        }
      },
      "required": [
        "logstore",
        "column"
      ],
      "anyOf": [
        {
          "required": [
            "datasource"
          ]
        },
        {
          "required": [
            "endpoint",
            "accessKeyId",
            "accessKeySecret",
            "project"
          ]
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
