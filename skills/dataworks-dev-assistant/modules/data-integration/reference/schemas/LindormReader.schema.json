{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lindorm Reader Schema",
  "description": "Lindorm reader configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIReaderBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "lindorm",
      "description": "Lindorm reader type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "configuration": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "selects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "datasource": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "tableMode": {
          "type": "string"
        },
        "table": {
          "type": "string"
        }
      },
      "required": [
        "datasource"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
