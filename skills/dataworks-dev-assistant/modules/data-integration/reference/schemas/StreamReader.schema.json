{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stream Reader Schema",
  "description": "Stream reader configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIReaderBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "stream",
      "description": "Stream reader type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "column": {
          "type": "array",
          "description": "Generated stream column definitions",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Generated value type"
              },
              "value": {
                "description": "Static value generated by Stream reader"
              },
              "dateFormat": {
                "type": "string",
                "description": "Date format pattern"
              },
              "random": {
                "type": "string",
                "description": "Random string generation range"
              }
            },
            "additionalProperties": true
          }
        },
        "sliceRecordCount": {
          "type": "string",
          "description": "Number of records generated by Stream reader"
        }
      },
      "required": [
        "column",
        "sliceRecordCount"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
