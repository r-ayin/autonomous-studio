{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OSS Writer Schema",
  "description": "OSS writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "oss",
      "description": "OSS writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "datasource": {
          "type": "string",
          "description": "Datasource name in DataWorks"
        },
        "object": {
          "type": "string",
          "description": "OSS object prefix"
        },
        "path": {
          "type": "string",
          "description": "OSS output path for ORC or Parquet writes"
        },
        "fileName": {
          "type": "string",
          "description": "Output file name prefix for ORC or Parquet writes"
        },
        "writeMode": {
          "type": "string",
          "enum": [
            "truncate",
            "append",
            "nonConflict"
          ],
          "description": "OSS writer mode"
        },
        "writeSingleObject": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ],
          "description": "Whether to write a single object"
        },
        "fileFormat": {
          "type": "string",
          "description": "Output file format"
        },
        "column": {
          "type": "array",
          "description": "Column definitions used for ORC or Parquet writes",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Column name"
              },
              "type": {
                "type": "string",
                "description": "Column type"
              }
            },
            "required": [
              "name",
              "type"
            ],
            "additionalProperties": true
          }
        },
        "fieldDelimiter": {
          "type": "string",
          "description": "Field delimiter"
        },
        "encoding": {
          "type": "string",
          "description": "Output encoding"
        },
        "compress": {
          "type": "string",
          "description": "Compression type"
        },
        "nullFormat": {
          "type": "string",
          "description": "Null value representation"
        },
        "dateFormat": {
          "type": "string",
          "description": "Date format pattern"
        },
        "parquetSchema": {
          "type": "string",
          "description": "Parquet schema definition"
        },
        "header": {
          "type": "array",
          "description": "Header row written to OSS",
          "items": {
            "type": "string"
          }
        },
        "maxFileSize": {
          "type": "integer",
          "description": "Maximum file size in MB"
        },
        "suffix": {
          "type": "string",
          "description": "Output file suffix"
        },
        "generateEmptyFile": {
          "type": "boolean",
          "description": "Whether to generate an empty file when source data is empty"
        },
        "ossBlockSize": {
          "type": "integer",
          "description": "OSS multipart upload block size in MB"
        }
      },
      "required": [
        "datasource",
        "writeMode"
      ],
      "anyOf": [
        {
          "required": [
            "object"
          ]
        },
        {
          "required": [
            "path",
            "fileName",
            "fileFormat"
          ]
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
