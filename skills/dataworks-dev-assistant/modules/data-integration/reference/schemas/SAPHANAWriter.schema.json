{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SAPHANA Writer Schema",
  "description": "SAP HANA writer configuration for DataWorks Data Integration",
  "type": "object",
  "allOf": [
    {
      "$ref": "DIWriterBase.schema.json"
    }
  ],
  "properties": {
    "stepType": {
      "const": "saphana",
      "description": "SAP HANA writer type"
    },
    "parameter": {
      "type": "object",
      "properties": {
        "datasource": {
          "type": "string"
        },
        "table": {
          "type": "string"
        },
        "column": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "preSql": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "postSql": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "batchSize": {
          "type": "integer"
        }
      },
      "required": [
        "datasource",
        "table",
        "column"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
